# ─── Lume vendor mock — replay + chaos configuration ────────────────────────
#
# These env vars are read by the meter-vendor service at startup (see
# compose.yml). Restart `meter-vendor` after editing to pick up changes:
#   docker compose restart meter-vendor
# ────────────────────────────────────────────────────────────────────────────

# Replay speed: how many wall-clock seconds map to one simulated day.
# Default 3 → one simulated day every 3 real seconds → ~5,500 readings/sec.
# Raise (5-10) if your webhook receiver can't keep up; lower for slo-mo demos.
REPLAY_SECONDS_PER_DAY=3

# Inclusive window of the LCL dataset to replay. The dataset covers
# 2012-11 through 2014-02; the default uses a quiet winter slice.
REPLAY_WINDOW_START=2013-12-01
REPLAY_WINDOW_END=2014-02-28

# When true, replay loops back to REPLAY_WINDOW_START after reaching END.
REPLAY_LOOP=true

# ─── Chaos knobs (calm defaults; flip with `make vendor-chaos`) ─────────────

# Probability that any one batch is duplicated (delivered twice with same
# delivery_id). Realistic: 0.01-0.05.
VENDOR_DUPLICATE_RATE=0.0

# Probability that readings within a batch are shuffled in time (simulating
# the vendor's out-of-order delivery from concurrent collectors).
VENDOR_REORDER_RATE=0.0

# Probability that a stale "late correction" reading (from a prior batch) is
# appended to the current batch.
VENDOR_LATE_RATE=0.0

# Comma-separated outage windows in "HH:MM-HH:MM" simulated-time format. While
# inside any window the delivery worker pauses sends entirely. Empty = no
# outages. Example: "02:15-02:25,07:00-07:05"
VENDOR_OUTAGE_SCHEDULE=
